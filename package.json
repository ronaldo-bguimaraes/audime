{
  "name": "audime",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "turbo": "^2.9.15"
  },
  "devDependencies": {
    "typescript": "5.8.3"
  },
  "scripts": {
    "dev:api": "turbo run dev --filter=@audime/api",
    "build:api": "turbo run build --filter=@audime/api",
    "start:api": "npm run start -w @audime/api",
    "prod:api": "npm ci && npm run build:api && npm run start:api"
  },
  "packageManager": "npm@11.15.0"
}
